# Cloudflare Pages headers (copied from public/ to the build root).

# Content-hashed assets: safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML shell + service worker: always revalidate so deploys/updates are picked up.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Sample shader: default type is octet-stream; set the real type so it compresses.
/example.wgsl
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
